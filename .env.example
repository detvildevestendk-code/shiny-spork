APP_ENV=development
APP_NAME=AI Futures Bot
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://bot:bot_password@postgres:5432/futures_bot
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_FILTER_ENABLED=true
AI_MIN_CONFIDENCE=0.62

EXCHANGE_NAME=bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true
PAPER_TRADING_EQUITY=10000
EXCHANGE_SANDBOX=true
HEDGE_MODE_ENABLED=true

MAX_LEVERAGE=10
DEFAULT_LEVERAGE=3
MAX_OPEN_TRADES=5
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITION_RISK_PCT=1.0
MAX_ACCOUNT_EXPOSURE_PCT=40.0
LOSING_STREAK_COOLDOWN_MINUTES=45
EXTREME_VOLATILITY_THRESHOLD_PCT=8.0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
