# AI Futures Bot production environment template
# Copy this file to .env and replace every CHANGE_ME_* value before deployment.
# Never commit .env. Keep live trading disabled until paper trading has been verified.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=production
APP_NAME=AI Futures Bot
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
API_DOCS_ENABLED=false

# Required. Generate at least 32 random characters.
# Example: openssl rand -hex 32
TRADING_API_KEY=CHANGE_ME_LONG_RANDOM_API_KEY

# Required. Comma-separated allowed browser origins for the dashboard.
# Local: http://localhost:5173
# Production example: https://bot.example.com
CORS_ALLOWED_ORIGINS=https://CHANGE_ME_DASHBOARD_DOMAIN

# Required. Public API URL used by the frontend runtime config.
# Production example: https://api.example.com
FRONTEND_API_BASE_URL=https://CHANGE_ME_API_DOMAIN

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
# For Docker Compose local Postgres. If using managed Postgres, these can still
# document the intended DB name/user, but DATABASE_URL is what the app uses.
POSTGRES_DB=futures_bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD

# Required. Async SQLAlchemy URL used by FastAPI/worker.
# Docker Compose local Postgres:
DATABASE_URL=postgresql+asyncpg://bot:CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD@postgres:5432/futures_bot
# Managed Postgres example:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB_NAME

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Required for Docker Compose Redis.
REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM_REDIS_PASSWORD

# Required. Redis URL used by FastAPI/worker.
# Docker Compose local Redis:
REDIS_URL=redis://:CHANGE_ME_LONG_RANDOM_REDIS_PASSWORD@redis:6379/0
# Managed Redis TLS example:
# REDIS_URL=rediss://USER:PASSWORD@HOST:6379/0

# -----------------------------------------------------------------------------
# AI filter
# -----------------------------------------------------------------------------
# OpenAI is optional for paper testing. If OPENAI_API_KEY is empty, paper mode
# can pass through analysis safely; live mode should not run without AI review.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_FILTER_ENABLED=true
AI_MIN_CONFIDENCE=0.62

# -----------------------------------------------------------------------------
# Exchange credentials
# -----------------------------------------------------------------------------
# Use testnet/sandbox keys for paper or testnet validation.
# Never enable withdrawal permissions on exchange API keys.
EXCHANGE_NAME=bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
HEDGE_MODE_ENABLED=true

# -----------------------------------------------------------------------------
# Trading mode safety
# -----------------------------------------------------------------------------
# Keep these defaults for first deployment. This prevents live exchange orders.
LIVE_TRADING_ENABLED=false
PAPER_TRADING_ENABLED=true
PAPER_TRADING_EQUITY=10000
EXCHANGE_SANDBOX=true

# To enable live trading later, change all three deliberately after a separate
# review: LIVE_TRADING_ENABLED=true, PAPER_TRADING_ENABLED=false,
# EXCHANGE_SANDBOX=false.

# -----------------------------------------------------------------------------
# Risk limits
# -----------------------------------------------------------------------------
MAX_LEVERAGE=10
DEFAULT_LEVERAGE=3
MAX_OPEN_TRADES=5
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITION_RISK_PCT=1.0
MAX_ACCOUNT_EXPOSURE_PCT=40.0
LOSING_STREAK_COOLDOWN_MINUTES=45
EXTREME_VOLATILITY_THRESHOLD_PCT=8.0

# -----------------------------------------------------------------------------
# Worker / strategy scanning
# -----------------------------------------------------------------------------
# Keep disabled until exchange connectivity and dashboard readiness are verified.
WORKER_STRATEGY_SCANNING_ENABLED=false
STRATEGY_SCAN_INTERVAL_SECONDS=60
TRADING_SYMBOLS=BTC/USDT:USDT
ENABLED_STRATEGIES=ema_crossover

# -----------------------------------------------------------------------------
# Telegram alerts
# -----------------------------------------------------------------------------
# Recommended before live trading. Optional for local paper testing.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
